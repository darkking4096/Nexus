# Local Development Environment Configuration
# Copy this file to .env.local and fill in your values

# ============================================
# Database Configuration (Supabase PostgreSQL)
# ============================================

# Primary connection string (choose one)
# Option 1: Full Supabase connection string
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@your-project.supabase.co:5432/postgres?sslmode=require

# Option 2: Component-based configuration (alternative)
# DB_HOST=your-project.supabase.co
# DB_PORT=5432
# DB_NAME=postgres
# DB_USER=postgres
# DB_PASSWORD=YOUR_PASSWORD

# Connection Pool Configuration
DB_POOL_MIN=5
DB_POOL_MAX=20
DB_CONNECTION_TIMEOUT=30000      # milliseconds
DB_IDLE_TIMEOUT=300000           # milliseconds (5 minutes)

# Retry Logic Configuration
DB_RETRY_MAX_ATTEMPTS=3
DB_RETRY_INITIAL_DELAY=100       # milliseconds
DB_RETRY_MAX_DELAY=5000          # milliseconds

# ============================================
# Backend Server Configuration
# ============================================

BACKEND_PORT=5000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================
# Redis Configuration (for caching & sessions)
# ============================================

REDIS_HOST=localhost
REDIS_PORT=6379

# ============================================
# Authentication & Security
# ============================================

JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long
AUTH_TOKEN_EXPIRY=24h

# ============================================
# Third-party API Keys
# ============================================

# Instagram Graph API
INSTAGRAM_APP_ID=your_app_id
INSTAGRAM_APP_SECRET=your_app_secret

# Claude/Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# ============================================
# Development Flags
# ============================================

NODE_ENV=development
DEBUG=false
