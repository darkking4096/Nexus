# Production Environment Configuration Template
#
# ⚠️  CRITICAL SECURITY WARNING ⚠️
# This is a TEMPLATE ONLY - DO NOT commit actual production credentials to git
#
# All production secrets must be stored in:
# - AWS Secrets Manager / Parameter Store
# - HashiCorp Vault
# - CI/CD platform secrets (GitHub Actions, GitLab CI, etc.)
# - Vercel/Netlify environment variables
#
# Production configuration is injected at deployment time
#
# For local production testing only:
# 1. Copy this file to .env.production (gitignored)
# 2. Fill in test values only
# 3. NEVER commit to version control

# ============================================
# Database Configuration
# ============================================

# DATABASE_URL should be injected at deployment time
# Format: postgresql://user:password@host:port/database?sslmode=require
#
# Example (DO NOT USE IN PRODUCTION):
# DATABASE_URL=postgresql://postgres:password@prod-db.supabase.co:5432/postgres?sslmode=require

# Connection Pool Configuration
# Tune these values based on expected traffic
DB_POOL_MIN=10
DB_POOL_MAX=50
DB_CONNECTION_TIMEOUT=30000
DB_IDLE_TIMEOUT=600000  # 10 minutes for production

# Retry Logic Configuration
DB_RETRY_MAX_ATTEMPTS=5
DB_RETRY_INITIAL_DELAY=100
DB_RETRY_MAX_DELAY=5000

# ============================================
# Backend Server Configuration
# ============================================

BACKEND_PORT=5000

# Only allow requests from your production domain
ALLOWED_ORIGINS=https://app.example.com

# ============================================
# Redis Configuration
# ============================================

# Use managed Redis service in production (AWS ElastiCache, Heroku Redis, etc.)
REDIS_HOST=prod-redis-endpoint.example.com
REDIS_PORT=6379

# Add authentication if Redis requires it
# REDIS_PASSWORD=your-redis-password

# ============================================
# Authentication & Security
# ============================================

# All secrets should be injected at runtime, not in this file
# JWT_SECRET=INJECTED_AT_DEPLOYMENT

AUTH_TOKEN_EXPIRY=24h

# ============================================
# Environment Flags
# ============================================

NODE_ENV=production
DEBUG=false
LOG_LEVEL=info

# ============================================
# Monitoring & Observability
# ============================================

# Sentry error tracking
# SENTRY_DSN=https://...@sentry.io/...

# CloudWatch/DataDog metrics
# METRICS_ENDPOINT=...
