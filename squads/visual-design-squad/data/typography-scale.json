{
  "metadata": {
    "name": "Typography Scale",
    "version": "1.0.0",
    "lastUpdated": "2026-04-07",
    "description": "Modular Scale typography system for visual design squad",
    "basis": "Modular Scale (1.125 ratio, golden ratio derivative)",
    "baseSize": "16px (1rem)",
    "baseFontFamily": "Inter"
  },
  "scale": {
    "xs": {
      "size": "0.75rem",
      "pixels": "12px",
      "weight": 400,
      "lineHeight": 1.4,
      "letterSpacing": "0",
      "name": "Extra Small",
      "usage": "Captions, badge text, micro UI",
      "example": "Caption or micro text"
    },
    "sm": {
      "size": "0.875rem",
      "pixels": "14px",
      "weight": 400,
      "lineHeight": 1.5,
      "letterSpacing": "0",
      "name": "Small",
      "usage": "Small text, helper text, form labels",
      "example": "Helper text and small labels"
    },
    "base": {
      "size": "1rem",
      "pixels": "16px",
      "weight": 400,
      "lineHeight": 1.6,
      "letterSpacing": "0",
      "name": "Base",
      "usage": "Body text, paragraphs, list items",
      "example": "Regular body text for reading content and paragraphs."
    },
    "md": {
      "size": "1.125rem",
      "pixels": "18px",
      "weight": 400,
      "lineHeight": 1.6,
      "letterSpacing": "-0.01em",
      "name": "Medium",
      "usage": "Larger body text, intro paragraphs",
      "example": "Medium text for emphasis within body"
    },
    "lg": {
      "size": "1.25rem",
      "pixels": "20px",
      "weight": 500,
      "lineHeight": 1.5,
      "letterSpacing": "-0.01em",
      "name": "Large",
      "usage": "Subheadings, card titles",
      "example": "Large text for emphasis"
    },
    "xl": {
      "size": "1.5rem",
      "pixels": "24px",
      "weight": 600,
      "lineHeight": 1.4,
      "letterSpacing": "-0.02em",
      "name": "Extra Large",
      "usage": "H3 headings, section titles",
      "example": "Extra Large Heading Text"
    },
    "2xl": {
      "size": "2rem",
      "pixels": "32px",
      "weight": 600,
      "lineHeight": 1.3,
      "letterSpacing": "-0.02em",
      "name": "2XL",
      "usage": "H2 headings, major section titles",
      "example": "2XL Heading Text"
    },
    "3xl": {
      "size": "2.5rem",
      "pixels": "40px",
      "weight": 700,
      "lineHeight": 1.2,
      "letterSpacing": "-0.02em",
      "name": "3XL",
      "usage": "H1 headings (secondary), page titles",
      "example": "3XL Heading Text"
    },
    "4xl": {
      "size": "3rem",
      "pixels": "48px",
      "weight": 700,
      "lineHeight": 1.2,
      "letterSpacing": "-0.03em",
      "name": "4XL",
      "usage": "Large hero headings",
      "example": "4XL Heading Text"
    },
    "5xl": {
      "size": "3.5rem",
      "pixels": "56px",
      "weight": 700,
      "lineHeight": 1.1,
      "letterSpacing": "-0.03em",
      "name": "5XL",
      "usage": "H1 hero headings, major titles",
      "example": "5XL Heading Text"
    }
  },
  "headings": {
    "h1": {
      "size": "3.5rem",
      "pixels": "56px",
      "weight": 700,
      "lineHeight": 1.1,
      "letterSpacing": "-0.03em",
      "scale": "5xl",
      "usage": "Page title, hero section"
    },
    "h2": {
      "size": "2rem",
      "pixels": "32px",
      "weight": 600,
      "lineHeight": 1.3,
      "letterSpacing": "-0.02em",
      "scale": "2xl",
      "usage": "Section heading"
    },
    "h3": {
      "size": "1.5rem",
      "pixels": "24px",
      "weight": 600,
      "lineHeight": 1.4,
      "letterSpacing": "-0.02em",
      "scale": "xl",
      "usage": "Subsection heading"
    },
    "h4": {
      "size": "1.25rem",
      "pixels": "20px",
      "weight": 600,
      "lineHeight": 1.5,
      "letterSpacing": "-0.01em",
      "scale": "lg",
      "usage": "Card title, emphasis heading"
    },
    "h5": {
      "size": "1.125rem",
      "pixels": "18px",
      "weight": 600,
      "lineHeight": 1.5,
      "letterSpacing": "-0.01em",
      "scale": "md",
      "usage": "Smaller emphasis heading"
    },
    "h6": {
      "size": "1rem",
      "pixels": "16px",
      "weight": 600,
      "lineHeight": 1.5,
      "letterSpacing": "0",
      "scale": "base",
      "usage": "Label, tag heading"
    }
  },
  "bodyText": {
    "paragraph": {
      "size": "1rem",
      "weight": 400,
      "lineHeight": 1.6,
      "letterSpacing": "0",
      "maxLineLength": "65-75 characters",
      "usage": "Main body paragraph text"
    },
    "smallText": {
      "size": "0.875rem",
      "weight": 400,
      "lineHeight": 1.5,
      "letterSpacing": "0",
      "usage": "Captions, helper text, metadata"
    },
    "largeText": {
      "size": "1.125rem",
      "weight": 400,
      "lineHeight": 1.6,
      "letterSpacing": "-0.01em",
      "usage": "Intro paragraphs, emphasized body"
    }
  },
  "fontFamilies": {
    "sans": {
      "name": "Inter",
      "stack": "Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
      "weights": [400, 500, 600, 700],
      "usage": "Default font for all UI, headings, body"
    },
    "mono": {
      "name": "JetBrains Mono",
      "stack": "'JetBrains Mono', 'Courier New', monospace",
      "weights": [400, 500],
      "usage": "Code snippets, technical content"
    }
  },
  "fontWeights": {
    "regular": 400,
    "medium": 500,
    "semibold": 600,
    "bold": 700
  },
  "lineHeights": {
    "tight": 1.1,
    "snug": 1.2,
    "normal": 1.5,
    "relaxed": 1.6,
    "loose": 1.8
  },
  "letterSpacing": {
    "tighter": "-0.03em",
    "tight": "-0.02em",
    "normal": "0em",
    "wide": "0.01em",
    "wider": "0.02em"
  },
  "fluidTypography": {
    "enabled": true,
    "method": "clamp()",
    "examples": {
      "heading1": "clamp(2rem, 5vw, 3.5rem)",
      "heading2": "clamp(1.5rem, 4vw, 2rem)",
      "body": "clamp(0.875rem, 2vw, 1.125rem)"
    }
  },
  "responsiveScales": {
    "mobile": {
      "h1": "2.5rem",
      "h2": "1.75rem",
      "h3": "1.25rem",
      "body": "0.875rem"
    },
    "tablet": {
      "h1": "3rem",
      "h2": "1.875rem",
      "h3": "1.375rem",
      "body": "1rem"
    },
    "desktop": {
      "h1": "3.5rem",
      "h2": "2rem",
      "h3": "1.5rem",
      "body": "1rem"
    }
  },
  "accessibility": {
    "minimumFontSize": "16px (prevents auto-zoom on iOS)",
    "minimumLineHeight": "1.5",
    "maximumLineLength": "75 characters",
    "contrastRatios": {
      "normalText": "4.5:1 minimum",
      "largeText": "3:1 minimum (18pt+)"
    },
    "colorContrastPairs": [
      {
        "text": "Primary text (#1F2937)",
        "background": "White",
        "ratio": "19:1",
        "status": "Pass WCAG AAA"
      }
    ]
  },
  "cssVariables": {
    "enabled": true,
    "pattern": "--font-{size|weight}",
    "examples": {
      "fontSizes": {
        "xs": "var(--font-size-xs)",
        "sm": "var(--font-size-sm)",
        "base": "var(--font-size-base)"
      },
      "fontWeights": {
        "regular": "var(--font-weight-regular)",
        "bold": "var(--font-weight-bold)"
      },
      "lineHeights": {
        "tight": "var(--line-height-tight)",
        "relaxed": "var(--line-height-relaxed)"
      }
    }
  },
  "notes": "This scale uses Modular Scale (1.125 ratio) for harmonious size relationships. All sizes are fluid and responsive. Font sizes are minimum 16px on mobile to prevent iOS auto-zoom."
}
