# Test Environment Configuration
NODE_ENV=test

# Playwright E2E Configuration
PLAYWRIGHT_BASE_URL=http://localhost:3000
PLAYWRIGHT_API_URL=http://localhost:3001

# Backend Configuration
PORT=3001
LOG_LEVEL=warn

# Database (Test - use staging Supabase)
# These will be overridden by CI environment if running in GitHub Actions
DATABASE_URL=postgresql://test:test@localhost:5432/nexus_test
SUPABASE_URL=https://xyzabc.supabase.co
SUPABASE_KEY=your-test-supabase-key

# Authentication (Test tokens/secrets)
JWT_SECRET=test-secret-very-long-key-for-testing-only
JWT_EXPIRATION=7d

# Email (Disable in tests)
EMAIL_SERVICE_DISABLED=true

# Feature Flags
FEATURE_FLAGS_ENABLED=true

# Logging
DEBUG=false
