# Backend Configuration

# Server
BACKEND_PORT=5000
DATABASE_PATH=data/nexus.db

# CORS
ALLOWED_ORIGINS=http://localhost:5173

# JWT Secrets (generate with: openssl rand -hex 32)
JWT_ACCESS_SECRET=your-access-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here

# Encryption (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=your-encryption-key-32-bytes-hex

# Python Instagrapi Service
PYTHON_SERVICE_URL=http://localhost:5001

# Claude API (for Research Squad)
ANTHROPIC_API_KEY=your-anthropic-api-key
RESEARCH_MODEL=claude-sonnet-4-5-20251001

# Playwright
HEADLESS=true

# Redis Cache (optional, falls back to in-memory if not available)
REDIS_HOST=localhost
REDIS_PORT=6379

# Database
# Leave commented out to use default (data/nexus.db)
# DATABASE_PATH=/path/to/database.db
