{
  "name": "nexus-backend",
  "version": "1.0.0",
  "description": "NEXUS Backend - Express API",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:migrations": "vitest tests/migrations",
    "test:with-db": "npm run db:start && npm test && npm run db:stop || npm run db:stop",
    "db:start": "docker run -d --name nexus-test-postgres -e POSTGRES_PASSWORD=Darkking4096. -e POSTGRES_USER=postgres -e POSTGRES_DB=nexus_test -p 5432:5432 --rm postgres:15-alpine && sleep 3",
    "db:stop": "docker stop nexus-test-postgres 2>/dev/null || true",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "migrate:data": "tsx scripts/migrate-data.ts",
    "db:test": "node scripts/apply-migrations.mjs",
    "test:e2e": "playwright test",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report test-results/e2e",
    "seed:test-data": "tsx scripts/seed-test-data.ts",
    "seed:test-data:api": "tsx scripts/seed-test-data.ts --api http://localhost:3001"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "jsonwebtoken": "^9.0.0",
    "pg": "^8.20.0",
    "playwright": "^1.42.0",
    "redis": "^4.6.11",
    "sharp": "^0.33.5",
    "vite": "8.0.8"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.10.6",
    "@types/pg": "^8.10.7",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitest/ui": "^1.1.0",
    "eslint": "^8.56.0",
    "multer": "^2.1.1",
    "supertest": "^7.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.4"
  }
}
