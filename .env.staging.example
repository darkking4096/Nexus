# Staging Environment Configuration
# This file is used for staging deployments
# Actual credentials are stored in CI/CD environment variables

# ============================================
# Database Configuration (Supabase PostgreSQL - Staging)
# ============================================

# Connection string (set via CI/CD environment variable in production)
# DATABASE_URL=postgresql://postgres:...@staging-project.supabase.co:5432/postgres?sslmode=require

# Connection Pool Configuration
DB_POOL_MIN=5
DB_POOL_MAX=20
DB_CONNECTION_TIMEOUT=30000
DB_IDLE_TIMEOUT=300000

# Retry Logic Configuration
DB_RETRY_MAX_ATTEMPTS=3
DB_RETRY_INITIAL_DELAY=100
DB_RETRY_MAX_DELAY=5000

# ============================================
# Backend Server Configuration
# ============================================

BACKEND_PORT=5000
ALLOWED_ORIGINS=https://staging.example.com,https://app-staging.example.com

# ============================================
# Redis Configuration
# ============================================

REDIS_HOST=staging-redis-host
REDIS_PORT=6379

# ============================================
# Authentication & Security
# ============================================

# JWT_SECRET is provided via CI/CD environment variable
# Never commit actual secrets to this file

AUTH_TOKEN_EXPIRY=24h

# ============================================
# Third-party API Keys
# ============================================

# All API keys are provided via CI/CD environment variables
# This ensures secrets are never committed to version control

# ============================================
# Environment Flags
# ============================================

NODE_ENV=staging
DEBUG=false
