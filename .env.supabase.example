# ============================================================================
# Story 8.1.1: Supabase Database Configuration
# ============================================================================

# Database Connection (Supabase PostgreSQL)
DB_HOST=your-project-ref.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your_secure_database_password
DB_SSL=true

# SQLite (source database for migration)
SQLITE_DB_PATH=packages/backend/data/nexus.db

# API Configuration
API_URL=http://localhost:5000
API_ENVIRONMENT=development

# Supabase Project Configuration
SUPABASE_PROJECT_ID=your-project-id
SUPABASE_API_KEY=your-supabase-api-key
SUPABASE_URL=https://your-project-ref.supabase.co

# Backup Configuration
BACKUP_SCHEDULE=daily
BACKUP_RETENTION_DAYS=30

# Row-Level Security Configuration
RLS_ENABLED=true
AUTH_PROVIDER=jwt

# Migration Configuration
MIGRATE_DRY_RUN=false
MIGRATE_BATCH_SIZE=100
MIGRATE_TIMEOUT_MS=30000

# Notes:
# 1. Get DB_HOST and DB_PASSWORD from Supabase Dashboard → Settings → Database
# 2. Use Connection Pooler endpoint (recommended for applications)
# 3. DB_SSL must be true for Supabase
# 4. Never commit actual passwords to git — use .env.local or environment variables
# 5. For production, use Supabase environment variables feature
