# Story 7.1 — E2E Test Environment Variables
# Copy this file to .env.test and fill in your values
# .env.test is gitignored and should NOT be committed

# Test User Credentials
TEST_USER_EMAIL=qa-tester-e2e@synkra.test
TEST_USER_PASSWORD=SecureTestPassword123!

# Instagram Test Account
INSTAGRAM_TEST_HANDLE=synkra-e2e-test
INSTAGRAM_TEST_PASSWORD=TestAcctPassword123!
INSTAGRAM_GRAPH_TOKEN=your_test_graph_token_here
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_business_account_id_here

# Staging Environment
STAGING_URL=http://localhost:3000
BASE_URL=http://localhost:3000

# Optional: Email service mock
EMAIL_SERVICE=mock  # Options: mock, sendgrid, custom

# Optional: Performance thresholds
DASHBOARD_LOAD_TIMEOUT_MS=2000
CONTENT_GENERATION_TIMEOUT_MS=30000
API_RESPONSE_TIMEOUT_MS=200
